APP_NAME=Voice Twitter
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://voice:voice@localhost:5432/voice_twitter
REDIS_URL=redis://localhost:6379/0

BACKEND_ORIGIN=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:5173

SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

UPLOADS_DIR=../uploads
MAX_UPLOAD_BYTES=10485760
MAX_AUDIO_SECONDS=300
AUDIO_ENHANCEMENT_ENABLED=true
AUDIO_HIGHPASS_HZ=80
AUDIO_LOWPASS_HZ=7600
AUDIO_NOISE_REDUCTION_ENABLED=false
AUDIO_LOUDNORM_ENABLED=true
AUDIO_LOUDNORM_I=-16.0
AUDIO_LOUDNORM_TP=-1.5
AUDIO_LOUDNORM_LRA=11.0
AUDIO_FFMPEG_TIMEOUT_SECONDS=180

STORAGE_BACKEND=local
STORAGE_BUCKET=
STORAGE_REGION=ru-central1
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PRESIGN_EXPIRE_SECONDS=3600

WHISPER_MODEL_SIZE=dvislobokov/faster-whisper-large-v3-turbo-russian
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=1
WHISPER_LANGUAGE=ru
WHISPER_TASK=transcribe
WHISPER_BEAM_SIZE=7
WHISPER_BEST_OF=3
WHISPER_PATIENCE=1.0
WHISPER_LENGTH_PENALTY=1.0
WHISPER_REPETITION_PENALTY=1.05
WHISPER_NO_REPEAT_NGRAM_SIZE=0
WHISPER_TEMPERATURE=0.0
WHISPER_TEMPERATURE_FALLBACK=0.0,0.2,0.4,0.6
WHISPER_COMPRESSION_RATIO_THRESHOLD=1.35
WHISPER_LOG_PROB_THRESHOLD=-1.0
WHISPER_NO_SPEECH_THRESHOLD=0.6
WHISPER_VAD_FILTER=true
WHISPER_VAD_THRESHOLD=0.5
WHISPER_VAD_MIN_SILENCE_DURATION_MS=700
WHISPER_VAD_MIN_SPEECH_DURATION_MS=150
WHISPER_VAD_SPEECH_PAD_MS=400
WHISPER_CONDITION_ON_PREVIOUS_TEXT=false
WHISPER_PROMPT_RESET_ON_TEMPERATURE=0.5
WHISPER_INITIAL_PROMPT=
WHISPER_HOTWORDS=
WHISPER_WORD_TIMESTAMPS=false
WHISPER_HALLUCINATION_SILENCE_THRESHOLD=
WHISPER_LANGUAGE_DETECTION_THRESHOLD=0.7
WHISPER_LANGUAGE_DETECTION_SEGMENTS=2
WHISPER_MODEL_DIR=../.cache/whisper
WHISPER_LOAD_TIMEOUT_SECONDS=600
CELERY_QUEUE_NAME=celery
TRANSCRIPTION_MAX_RETRIES=3
TRANSCRIPTION_RETRY_DELAY_SECONDS=30
TRANSCRIPTION_SOFT_TIME_LIMIT_SECONDS=1200
TRANSCRIPTION_HARD_TIME_LIMIT_SECONDS=1500
TRANSCRIPTION_REPLACEMENTS=
TRANSCRIPTION_POSTPROCESS_ENABLED=true
TRANSCRIPTION_POSTPROCESS_MODE=rules+llm
TRANSCRIPTION_POSTPROCESS_LLM_REQUIRED=false
TRANSCRIPTION_POSTPROCESS_REPLACEMENTS=
TRANSCRIPTION_POSTPROCESS_CAPITALIZE_SENTENCES=true
TRANSCRIPTION_POSTPROCESS_LLM_API_KEY=
TRANSCRIPTION_POSTPROCESS_LLM_BASE_URL=https://api.openai.com/v1
TRANSCRIPTION_POSTPROCESS_LLM_MODEL=
TRANSCRIPTION_POSTPROCESS_LLM_TIMEOUT_SECONDS=30
TRANSCRIPTION_POSTPROCESS_LLM_MAX_CHARS=5000
TRANSCRIPTION_POSTPROCESS_LLM_TEMPERATURE=0.0
TRANSCRIPTION_POSTPROCESS_LLM_SYSTEM_PROMPT=Ты редактор ASR-транскрипций. Исправляй только очевидные ошибки распознавания, орфографию, пунктуацию и капитализацию. Не добавляй новые факты, не меняй смысл, не вырезай важные слова. Сохраняй URL, @mentions, #hashtags и формат чисел.

AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_REGISTER_RATE_LIMIT=3/minute
TWEET_CREATE_RATE_LIMIT=10/minute
TWEET_DELETE_RATE_LIMIT=30/minute

ADMIN_EMAIL=admin@voice-tweet.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeAdmin123!
